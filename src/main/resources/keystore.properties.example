# =============================================================================
#  Configuració del magatzem de claus per signar les peticions (WS-Security / XMLDSIG).
#  Copieu aquest fitxer a 'keystore.properties' i ompliu-lo amb les dades del
#  vostre certificat:
#    cp keystore.properties.example keystore.properties
#
#  IMPORTANT: el fitxer del certificat (.p12/.jks) i el 'keystore.properties' amb
#  dades reals NO s'han de versionar mai (vegeu .gitignore).
# =============================================================================

# Proveïdor criptogràfic (Merlin és la implementació estàndard de WSS4J).
org.apache.ws.security.crypto.provider=org.apache.wss4j.common.crypto.Merlin

# Àlies del certificat dins del magatzem.
org.apache.ws.security.crypto.merlin.keystore.alias=el_meu_alias

# Format del magatzem (PKCS12 o JKS).
org.apache.ws.security.crypto.merlin.keystore.type=PKCS12

# Contrasenya del magatzem/certificat.
org.apache.ws.security.crypto.merlin.keystore.password=CANVIEU_AQUESTA_CONTRASENYA

# Ruta al fitxer del certificat. Useu barres '/' per compatibilitat multiplataforma.
org.apache.ws.security.crypto.merlin.keystore.file=src/main/resources/el_meu_certificat.p12
